# Copy this file to ".env" and fill in your values for LOCAL runs.
# In GitHub Actions these are provided as repository Secrets/Variables instead.

# --- Listings API (Marketcheck is primary) ---
PROVIDER=marketcheck
MARKETCHECK_API_KEY=your_marketcheck_key_here
# AUTODEV_API_KEY=your_autodev_key_here   # only if PROVIDER=autodev

# --- Search settings ---
PRICE_MAX=70000
SEARCH_RADIUS_MILES=3000
HOME_ZIP=97488
# Precise coords for Vida, OR (defaults already set in config.py):
# HOME_LAT=44.1460
# HOME_LON=-122.5698
MAX_MILES=                # blank = no mileage cap; e.g. 60000 to require <60k mi
REQUIRE_CLEAN_TITLE=true
TOP_N_EMAIL=12

# --- Email (Gmail app password) ---
GMAIL_USER=acmcveigh@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
EMAIL_TO=tommcveigh@yahoo.com
EMAIL_FROM_NAME=Cybertruck Tracker
